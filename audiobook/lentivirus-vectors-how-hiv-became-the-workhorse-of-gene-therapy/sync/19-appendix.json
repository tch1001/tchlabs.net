  {
   "t": 0.05,
   "text": "APPENDIX"
  },
  {
   "t": 1.07,
   "text": "Glossary of key terms"
  },
  {
   "t": 3.35,
   "text": "Lentivirus."
  },
  {
   "t": 4.59,
   "text": "A genus of complex retroviruses including HIV-1, HIV-2, SIV, FIV."
  },
  {
   "t": 14.06,
   "text": "Defining property as a vector: can cross intact nuclear envelopes and transduce non-dividing cells."
  },
  {
   "t": 21.34,
   "text": "Transfer plasmid."
  },
  {
   "t": 22.8,
   "text": "The plasmid carrying the vector RNA — psi, RRE, cPPT, internal promoter, transgene, WPRE, between SIN LTRs."
  },
  {
   "t": 33.83,
   "text": "Packaging plasmid."
  },
  {
   "t": 35.21,
   "text": "Provides Gag-Pol proteins in trans."
  },
  {
   "t": 38.33,
   "text": "Third-generation: gag-pol only, no tat, no accessory genes."
  },
  {
   "t": 43.83,
   "text": "Envelope plasmid."
  },
  {
   "t": 45.2,
   "text": "Provides the surface glycoprotein."
  },
  {
   "t": 47.79,
   "text": "Default: VSV-G."
  },
  {
   "t": 50.08,
   "text": "Rev plasmid."
  },
  {
   "t": 51.31,
   "text": "Third-generation systems split rev onto its own plasmid for safety."
  },
  {
   "t": 56.52,
   "text": "SIN."
  },
  {
   "t": 57.3,
   "text": "Self-inactivating."
  },
  {
   "t": 58.79,
   "text": "U3 enhancer deletion in 3' LTR is copied to both LTRs of the integrated provirus, eliminating LTR-driven transcription."
  },
  {
   "t": 68.88,
   "text": "Pseudotyping."
  },
  {
   "t": 70.04,
   "text": "Swapping the natural envelope for one from a different virus, changing tropism."
  },
  {
   "t": 75.69,
   "text": "VSV-G."
  },
  {
   "t": 77.05,
   "text": "Glycoprotein of vesicular stomatitis virus."
  },
  {
   "t": 80.62,
   "text": "Binds LDL receptor."
  },
  {
   "t": 82.66,
   "text": "Broad tropism, mechanically robust."
  },
  {
   "t": 85.4,
   "text": "Psi (ψ)."
  },
  {
   "t": 87.14,
   "text": "Packaging signal recognized by nucleocapsid domain of Gag."
  },
  {
   "t": 91.53,
   "text": "RRE."
  },
  {
   "t": 92.44,
   "text": "Rev response element."
  },
  {
   "t": 94.15,
   "text": "Binds Rev for nuclear export of unspliced RNA."
  },
  {
   "t": 98.49,
   "text": "cPPT."
  },
  {
   "t": 99.72,
   "text": "Central polypurine tract."
  },
  {
   "t": 101.71,
   "text": "Generates DNA flap, enhances nuclear import."
  },
  {
   "t": 105.79,
   "text": "WPRE."
  },
  {
   "t": 106.89,
   "text": "Woodchuck hepatitis posttranscriptional regulatory element."
  },
  {
   "t": 111.44,
   "text": "Enhances expression."
  },
  {
   "t": 112.99,
   "text": "MOI."
  },
  {
   "t": 113.65,
   "text": "Multiplicity of infection."
  },
  {
   "t": 115.81,
   "text": "Transducing units per target cell."
  },
  {
   "t": 118.56,
   "text": "LEDGF/p75."
  },
  {
   "t": 122.15,
   "text": "Cellular tether that targets lentiviral integrase to active gene bodies."
  },
  {
   "t": 127.26,
   "text": "IDLV."
  },
  {
   "t": 128.26,
   "text": "Integration-deficient lentiviral vector."
  },
  {
   "t": 131.0,
   "text": "Carries a catalytically dead integrase (D64V)."
  },
  {
   "t": 135.56,
   "text": "TU."
  },
  {
   "t": 136.21,
   "text": "Transducing units."
  },
  {
   "t": 137.93,
   "text": "Functional titer measure."
  },
  {
   "t": 139.53,
   "text": "p24."
  },
  {
   "t": 140.69,
   "text": "HIV capsid protein."
  },
  {
   "t": 142.91,
   "text": "Measured by ELISA to estimate total particle counts."
  },
  {
   "t": 146.47,
   "text": "RCL."
  },
  {
   "t": 147.47,
   "text": "Replication-competent lentivirus."
  },
  {
   "t": 150.15,
   "text": "Tested for in clinical batches; essentially never detected in third-generation products."
  },
  {
   "t": 155.94,
   "text": "Suggested reading"
  },
  {
