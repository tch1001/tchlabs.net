  },
  {
   "t": 229.36,
   "text": "\"Chimeric antigen receptor therapy."
  },
  {
   "t": 232.32,
   "text": "\" NEJM 379: 64."
  },
  {
   "t": 236.28,
   "text": "Addgene's lentivirus protocols and vector guides (addgene.org/protocols/lentivirus-production/)."
  },
  {
   "t": 244.93,
   "text": "Key numbers to remember"
  },
  {
   "t": 246.54,
   "text": "Lentiviral cargo capacity: ~8-10 kb between LTRs."
  },
  {
   "t": 252.19,
   "text": "Typical research-grade unconcentrated titer: 10^6 to 10^7 TU/mL."
  },
  {
   "t": 260.69,
   "text": "Concentrated titer after ultracentrifugation: 10^8 to 10^9 TU/mL."
  },
  {
   "t": 269.21,
   "text": "Particle-to-infectivity ratio: ~100 to 1000."
  },
  {
   "t": 273.29,
   "text": "Producer cell standard: HEK293T."
  },
  {
   "t": 277.99,
   "text": "Harvest timing: 48-96 hours post-transfection."
  },
  {
   "t": 282.65,
   "text": "Integration site bias: ~75% in active gene bodies."
  },
  {
   "t": 287.69,
   "text": "Generations in clinical use: 3rd (with SIN LTRs)."
  },
  {
   "t": 292.71,
   "text": "First FDA-approved lentiviral gene therapy product: Kymriah (CAR-T), 2017."
  }
 ]
}